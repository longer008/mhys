# ============================================================
# AI 服务配置（仅服务端读取）
# ============================================================
# 站点默认配置仅服务端读取；用户也可在浏览器中配置自己的 OpenAI 兼容服务。

# OpenAI 兼容 API Key（生产环境必填）
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI 兼容 API 地址（生产环境必填，必须使用 HTTPS）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（生产环境必填）
OPENAI_MODEL=gpt-4.1-mini

# ============================================================
# PostgreSQL 配置
# ============================================================

# Vercel 运行时连接：现有 Session Pooler 5432 可用，高并发推荐 Transaction Pooler 6543
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# 仅执行迁移时使用：Supabase Session Pooler 或 Direct Connection（端口 5432）
# 不要将此变量提供给浏览器代码。
# DIRECT_DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ============================================================
# 会话与后台配置
# ============================================================

# 管理后台密码（至少 7 个字符）
# ADMIN_PASSWORD=your-long-random-admin-password

# 管理员 Session 签名密钥（至少 32 个字符）
# ADMIN_SESSION_SECRET=your-random-32-character-secret-key

# 匿名用户 Session 签名密钥（至少 32 个字符，必须与管理员密钥不同）
# ANONYMOUS_SESSION_SECRET=your-anonymous-session-secret-at-least-32-chars

# 页面标题（可选）
SITE_TITLE=梅花易数

# ============================================================
# AI 额度配置（可选，以下为安全默认值）
# ============================================================

AI_USER_LIMIT_PER_10_MINUTES=5
AI_USER_DAILY_LIMIT=20
AI_IP_LIMIT_PER_10_MINUTES=20
AI_GLOBAL_DAILY_LIMIT=500
